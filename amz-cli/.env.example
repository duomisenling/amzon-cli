# 源码开发：复制本文件为项目 .env，填入真实值后运行。
# 全局安装：运行 amz-cli config init，使用 ~/.amz-cli/.env（模板见 .env.local.example）。
# 真实 .env 已被 .gitignore 忽略，不会提交。
# 这几个值别发给任何人(包括聊天)。
#
# ══ 两种模式,二选一 ══
#
# 【Broker 模式】(已部署 Broker 服务器时使用;机器上不保存长期凭证,最安全)
#   只需下面 4 行,其余全部留空:
#   BROKER_URL=https://<broker 域名>.zeabur.app
#   TEAM_TOKEN=<管理员发给你的团队令牌>
#   STORE=<店铺代号,如 SHOP_A>
#   SP_API_REGION=na
#
# 【本地模式】(未部署 Broker 时使用;开发者本机或管理员授权的小范围可信同事)
#   不设 BROKER_URL,填下面的 LWA_*(以及可选的 ADS_*)。
#   注意:refresh token 会保存在本机,是账号完整钥匙——只发给可信的人,
#   离职/丢机/疑似泄露时管理员必须立即到开发者中心吊销并重新授权。

# LWA 应用凭证(开发者中心 → 你的 App Client 里拿)
LWA_CLIENT_ID=
LWA_CLIENT_SECRET=

# 自我授权(Authorize)后拿到的 refresh_token
# refresh token 是按区域签发的:同一账号跨区域时,开发者中心的授权页会给
# 每个区域一个"授权"按钮,各点一次拿各自的 token。
#   单区域(旧写法,继续有效):LWA_REFRESH_TOKEN = 默认区域的 token
#   多区域:按区域分别填 LWA_REFRESH_TOKEN_NA / _EU / _FE
# 命令按 --marketplace 自动路由区域(查 DE 自动用 EU 的 token 和端点)。
LWA_REFRESH_TOKEN=
LWA_REFRESH_TOKEN_NA=
LWA_REFRESH_TOKEN_EU=
LWA_REFRESH_TOKEN_FE=

# 默认区域(不带 --marketplace 的命令用):na(US/CA) | eu(UK/DE/FR/IT/ES) | fe
SP_API_REGION=na

# 沙盒模式:true 时所有 SP-API 调用走亚马逊沙盒端点(返回官方预设 mock 数据,
# 不碰任何真实数据)。写操作先在这里验证。注意:静态沙盒按"参数匹配"工作,
# 请求参数须使用官方模型里预定义的示例值(不是你自己的 SKU/ASIN)。
SP_API_SANDBOX=false

# 卖家编号(listing mine/sku/update 需要)
# 查看方式:Seller Central → 设置 → 账户信息 → 商户令牌(Merchant Token)
# 注意:NA 和 EU 的卖家编号不同!多区域时分别配 SELLER_ID_NA / SELLER_ID_EU
# (SELLER_ID 不带后缀 = 各区域的兜底默认)
SELLER_ID=
SELLER_ID_NA=
SELLER_ID_EU=
SELLER_ID_FE=

# ―― 广告 API(可选;与上面 SP-API 凭证不是一套!)――
# 广告 API 需要在 Amazon Ads 控制台单独申请准入,refresh token 必须带
# advertising::campaign_management 权限。没配置时 ads 命令会尝试用上面的
# LWA_* 凭证(通常会被拒绝并给出明确提示)。
ADS_CLIENT_ID=
ADS_CLIENT_SECRET=
ADS_REFRESH_TOKEN=
ADS_REGION=na
# 广告凭证全区域通用:查欧洲广告不用改这里,命令加 --region eu 即可

# ―― 多账号(店铺)――
# 有多个亚马逊店铺时,每个店铺一份凭证文件放在 ~/.amz-cli/accounts/<名称>.env
# (内容格式与本文件相同,填该店铺自己的 LWA_REFRESH_TOKEN_* / SELLER_ID 等)。
# 运行时加 --account <名称> 即切换;不加 = 用本 .env(默认账号)。
# Broker 模式下 --account 直接切换店铺代号,员工机器无需任何账号文件；
# 管理员需在 Broker 为每个店铺/区域配置 SELLER_ID_<店铺>_<区域>,供 listing 命令使用。
