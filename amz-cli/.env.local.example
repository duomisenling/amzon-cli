# amz-cli 本地凭证模式模板
#
# 全局安装后，将本文件复制为：
#   Windows: %USERPROFILE%\.amz-cli\.env
#   macOS/Linux: ~/.amz-cli/.env
#
# 这是敏感文件：不要发送到聊天、邮件或 GitHub，不要截图。
# 同事电脑只填写实际需要的店铺和区域；未使用的区域保持为空。
# 本地模式不要填写 BROKER_URL / TEAM_TOKEN / STORE。

# Amazon SP-API 应用凭证
LWA_CLIENT_ID=
LWA_CLIENT_SECRET=

# 按区域填写 Refresh Token：NA=美国/加拿大，EU=英德法意西，FE=远东
LWA_REFRESH_TOKEN_NA=
LWA_REFRESH_TOKEN_EU=
LWA_REFRESH_TOKEN_FE=

# 默认区域：na | eu | fe
SP_API_REGION=na
SP_API_SANDBOX=false

# Seller ID（Merchant Token）也按区域隔离，避免跨区域误用
SELLER_ID_NA=
SELLER_ID_EU=
SELLER_ID_FE=

# Amazon Ads API（不用广告功能可全部留空）
ADS_CLIENT_ID=
ADS_CLIENT_SECRET=
ADS_REFRESH_TOKEN=
ADS_REGION=na
